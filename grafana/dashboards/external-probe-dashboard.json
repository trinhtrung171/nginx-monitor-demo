{
  "title": "External Probe — Blackbox Monitor",
  "uid": "external-probe-dashboard",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Probe Success",
      "type": "stat",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bool",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "HTTP Status Code",
      "type": "stat",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "probe_http_status_code",
          "legendFormat": "{{instance}}"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 }
    },
    {
      "id": 3,
      "title": "Response Duration",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "probe_duration_seconds",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 }
    }
  ]
}
