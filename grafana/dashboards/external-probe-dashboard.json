{
  "title": "External Probe — Blackbox Monitor",
  "uid": "external-probe-dashboard",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Probe Success",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bool",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.5 }
            ]
          },
          "custom": { "showPoints": "never" }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "HTTP Status Code",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "probe_http_status_code{job=\"blackbox\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "red", "value": 100 },
              { "color": "green", "value": 200 },
              { "color": "yellow", "value": 300 },
              { "color": "orange", "value": 400 },
              { "color": "red", "value": 500 }
            ]
          },
          "custom": { "showPoints": "never" }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 }
    },
    {
      "id": 3,
      "title": "Response Duration",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "probe_duration_seconds{job=\"blackbox\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 }
    }
  ]
}
