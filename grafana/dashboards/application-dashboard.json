{
  "title": "Application — API Performance",
  "uid": "application-dashboard",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Request/min",
      "type": "stat",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_total[1m]))",
          "legendFormat": "RPM"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rpm"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Error Rate %",
      "type": "gauge",
      "datasource": { "uid": "prometheus-local" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_total{status=~\"5..\"}[5m]) / rate(http_server_requests_total[5m]) * 100",
          "legendFormat": "5xx%"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "title": "p95 Latency",
      "type": "stat",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_duration_milliseconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 }
    },
    {
      "id": 4,
      "title": "Process CPU",
      "type": "gauge",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "process_cpu_usage",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 }
    },
    {
      "id": 5,
      "title": "Process RAM",
      "type": "gauge",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "process_memory_usage_bytes",
          "legendFormat": "RSS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 104857600 },
              { "color": "red", "value": 209715200 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 }
    },
    {
      "id": 6,
      "title": "Error Count",
      "type": "stat",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "sum(increase(app_errors_total[5m]))",
          "legendFormat": "Errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 }
    },
    {
      "id": 7,
      "title": "Render Uptime",
      "type": "stat",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox\", instance=\"https://nginx-monitor-demo.onrender.com/\"}",
          "legendFormat": "Uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bool",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 }
    }
  ]
}
