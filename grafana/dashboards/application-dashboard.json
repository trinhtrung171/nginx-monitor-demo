{
  "title": "Application — API Performance",
  "uid": "application-dashboard",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request/min",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "(sum(increase(http_server_requests_total[$__range])) * 60 / $__range_s) or vector(0)",
          "legendFormat": "RPM"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rpm",
          "color": { "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Error Rate %",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "(sum(increase(http_server_requests_total{status=~\"5..\"}[$__range])) / sum(increase(http_server_requests_total[$__range])) * 100) or vector(0)",
          "legendFormat": "5xx%"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 }
    },
    {
      "id": 3,
      "title": "p95 Latency",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "(histogram_quantile(0.95, sum by(le) (increase(http_server_duration_milliseconds_bucket[$__range]))) or vector(0))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 }
    },
    {
      "id": 4,
      "title": "Process CPU",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "avg(process_cpu_usage) * 100",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 30 }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 }
    },
    {
      "id": 5,
      "title": "Process RAM",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "avg(process_memory_usage_bytes)",
          "legendFormat": "RSS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 30 }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 }
    },
    {
      "id": 6,
      "title": "Error Count",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "(sum(increase(app_errors_total[$__range])) or vector(0))",
          "legendFormat": "Errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 30 }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 }
    },
    {
      "id": 7,
      "title": "Render Uptime",
      "type": "stat",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "avg(probe_success{job=\"blackbox\", instance=\"https://nginx-monitor-demo.onrender.com/\"})",
          "legendFormat": "Uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bool",
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 16 }
    }
  ]
}
