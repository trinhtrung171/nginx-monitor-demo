          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  a.\"createdAt\" AS \"Time\", \n  a.ip AS \"Client IP\", \n  COALESCE(u.username, 'Guest') AS \"User\",\n  a.\"userAgent\" AS \"Device/Browser\"\nFROM \"AccessLog\" a\nLEFT JOIN \"User\" u ON a.\"userId\" = u.id\nORDER BY a.\"createdAt\" DESC\nLIMIT 100;\n",
