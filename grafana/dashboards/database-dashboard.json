{
  "title": "Database Queries",
  "uid": "database-dashboard",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Slow Query Count",
      "type": "stat",
      "datasource": { "uid": "prometheus-local" },
      "targets": [
        {
          "expr": "sum(increase(slow_query_total[5m]))",
          "legendFormat": "Slow queries"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Live Slow Query Log",
      "type": "logs",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "{service=\"devshare-backend\"} |= \"slow_query\"",
          "legendFormat": ""
        }
      ],
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 }
    }
  ]
}
