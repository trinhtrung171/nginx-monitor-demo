{
  "title": "User Access Logs",
  "uid": "user-access-dashboard",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Top 10 IPs",
      "type": "table",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "topk(10, sum by(ip) (count_over_time({service=\"devshare-backend\"} | json | __error__!=\"JSONParserErr\" [$__range])))",
          "legendFormat": "__auto",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "color-text",
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "custom.displayName", "value": "Requests" },
              { "id": "custom.width", "value": 120 }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 10, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "User Journey",
      "type": "logs",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "{service=\"devshare-backend\"} | json | __error__!=\"JSONParserErr\" | line_format \"{{.timestamp | substr 0 19}} [{{.user_id | trunc 12}}] {{.method}} {{.path}} ({{.duration_ms}}ms, {{.status}})\"",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 10, "w": 14, "x": 10, "y": 0 }
    },
    {
      "id": 3,
      "title": "Avg Response Time",
      "type": "stat",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "avg(avg_over_time({service=\"devshare-backend\"} | json | __error__!=\"JSONParserErr\" | unwrap duration_ms [$__range]))",
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 100, "color": "yellow" },
              { "value": 500, "color": "red" }
            ]
          }
        }
      },
      "gridPos": { "h": 10, "w": 4, "x": 20, "y": 0 }
    },
    {
      "id": 4,
      "title": "HTTP Method Breakdown",
      "type": "piechart",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "sum by(method) (count_over_time({service=\"devshare-backend\"} | json | __error__!=\"JSONParserErr\" [$__range]))",
          "legendFormat": "__auto",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 10 }
    },
    {
      "id": 5,
      "title": "Status Code Breakdown",
      "type": "table",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "sum by(status) (count_over_time({service=\"devshare-backend\"} | json | __error__!=\"JSONParserErr\" [$__range]))",
          "legendFormat": "__auto",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "custom.displayName", "value": "Count" },
              { "id": "custom.width", "value": 120 }
            ]
          }
        ]
      },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 10 }
    },
    {
      "id": 6,
      "title": "Bandwidth per IP",
      "type": "table",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "topk(10, sum by(ip) (sum_over_time({service=\"devshare-backend\"} | json | __error__!=\"JSONParserErr\" | unwrap bytes_sent [$__range])))",
          "legendFormat": "__auto",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "custom.displayName", "value": "Bytes" },
              { "id": "custom.width", "value": 120 }
            ]
          }
        ]
      },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 10 }
    },
    {
      "id": 7,
      "title": "Total Requests per Endpoint",
      "type": "table",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "topk(10, sum by(path) (count_over_time({service=\"devshare-backend\"} | json | __error__!=\"JSONParserErr\" [$__range])))",
          "legendFormat": "__auto",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "custom.displayName", "value": "Requests" },
              { "id": "custom.width", "value": 120 }
            ]
          }
        ]
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 17 }
    },
    {
      "id": 8,
      "title": "Avg Response Time by Route",
      "type": "table",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "topk(10, sum by(path) (avg_over_time({service=\"devshare-backend\"} | json | __error__!=\"JSONParserErr\" | unwrap duration_ms [$__range])))",
          "legendFormat": "__auto",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "custom.displayName", "value": "Avg (ms)" },
              { "id": "custom.width", "value": 120 }
            ]
          }
        ]
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 17 }
    }
  ]
}
