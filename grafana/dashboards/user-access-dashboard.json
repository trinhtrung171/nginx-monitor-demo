      "type": "table",
      "datasource": {
        "type": "loki",
        "uid": "devshare-loki"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "devshare-loki"
          },
          "editorMode": "code",
          "expr": "sum by (ip) (count_over_time({service=\"devshare-backend\"} | json | __error__!=\"JSONParserErr\" [30m]))",
          "legendFormat": "Requests",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "devshare-loki"
          },
          "editorMode": "code",
          "expr": "avg by (ip) (avg_over_time({service=\"devshare-backend\"} | json | __error__!=\"JSONParserErr\" | unwrap duration_ms [30m]))",
