        {
          "dataset": "neondb",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "devshare-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  al.\"createdAt\",\n  al.\"ip\",\n  COALESCE(al.\"username\", 'Guest') AS \"Username\",\n  al.\"method\",\n  al.\"path\",\n  al.\"status\",\n  al.\"durationMs\" AS \"Duration (ms)\",\n  al.\"bytesSent\" AS \"Bytes Sent\"\nFROM \"AccessLog\" al\nWHERE al.\"method\" IS NOT NULL\nORDER BY al.\"createdAt\" DESC\nLIMIT 200;\n",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
