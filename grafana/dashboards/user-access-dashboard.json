{
  "title": "User Access Logs",
  "uid": "user-access-dashboard",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Top 10 IP Addresses",
      "type": "table",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "topk(10, sum by(ip) (count_over_time({service_name=\"devshare-backend\"} | json | __error__=\"\" [$__range])))",
          "legendFormat": "__auto",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "custom.displayName", "value": "Request Count" },
              { "id": "custom.width", "value": 160 }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "sum(rate({service_name=\"devshare-backend\"} | json | __error__=\"\" [1m]))",
          "legendFormat": "req/s",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "spanNulls": false,
            "showPoints": "never"
          }
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "title": "HTTP Status Distribution",
      "type": "piechart",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"devshare-backend\"} | json | __error__=\"\" | status >= 200 | status < 300 [$__range]))",
          "legendFormat": "2xx Success",
          "queryType": "instant",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({service_name=\"devshare-backend\"} | json | __error__=\"\" | status >= 300 | status < 400 [$__range]))",
          "legendFormat": "3xx Redirect",
          "queryType": "instant",
          "refId": "B"
        },
        {
          "expr": "sum(count_over_time({service_name=\"devshare-backend\"} | json | __error__=\"\" | status >= 400 | status < 500 [$__range]))",
          "legendFormat": "4xx Client Error",
          "queryType": "instant",
          "refId": "C"
        },
        {
          "expr": "sum(count_over_time({service_name=\"devshare-backend\"} | json | __error__=\"\" | status >= 500 [$__range]))",
          "legendFormat": "5xx Server Error",
          "queryType": "instant",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "displayLabels": ["name", "percent"]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 }
    },
    {
      "id": 4,
      "title": "Most Called Endpoints",
      "type": "barchart",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "topk(10, sum by(method, path) (count_over_time({service_name=\"devshare-backend\"} | json | __error__=\"\" [$__range])))",
          "legendFormat": "{{method}} {{path}}",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisPlacement": "auto",
            "barAlignment": -1,
            "barWidthFactor": 0.6
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "sort": "descending"
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 }
    },
    {
      "id": 5,
      "title": "User Activity Log",
      "type": "logs",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"devshare-backend\"} | json | __error__=\"\" | line_format \"{{.timestamp}} | {{.ip}} | {{.user_id}} | {{.method}} {{.path}} → {{.status}} ({{.duration_ms}}ms)\"",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 6,
      "title": "Bandwidth per IP (bytes sent)",
      "type": "table",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "topk(10, sum by(ip) (sum_over_time({service_name=\"devshare-backend\"} | json | __error__=\"\" | unwrap bytes_sent [$__range])))",
          "legendFormat": "__auto",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "custom.displayName", "value": "Bytes Sent" },
              { "id": "custom.width", "value": 160 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 }
    }
  ]
}
