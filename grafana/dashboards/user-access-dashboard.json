{
  "title": "User Access Logs",
  "uid": "user-access-dashboard",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Top 10 IPs",
      "type": "table",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "sum by(ip) (count_over_time({service=\"devshare-backend\"} | json | __error__!=\"JSONParserErr\" [1h]))",
          "legendFormat": "",
          "queryType": "range"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Requests by Endpoint",
      "type": "barchart",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "sum by(path) (count_over_time({service=\"devshare-backend\"} | json | __error__!=\"JSONParserErr\" [1h]))",
          "legendFormat": "",
          "queryType": "range"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "title": "HTTP Status Breakdown",
      "type": "piechart",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "sum by(status) (count_over_time({service=\"devshare-backend\"} | json | __error__!=\"JSONParserErr\" [1h]))",
          "legendFormat": "",
          "queryType": "range"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "title": "Avg Response Time by Route",
      "type": "stat",
      "datasource": { "uid": "devshare-loki", "type": "loki" },
      "targets": [
        {
          "expr": "sum by(path) (avg_over_time({service=\"devshare-backend\"} | json | __error__!=\"JSONParserErr\" | unwrap duration_ms [1h]))",
          "legendFormat": "",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
