# Docker credentials (for pushing to Docker Hub)
DOCKERHUB_USERNAME=your-dockerhub-username

# Gmail SMTP Configuration for Alertmanager
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_TO=recipient@example.com

# Grafana Admin Password
GF_PASSWORD=admin

# Public URL of your Vercel-deployed app (include https://)
VERCEL_URL=https://your-app.vercel.app

# OpenTelemetry Configuration (for Grafana Cloud)
OTEL_ENDPOINT=https://otlp-gateway-prod-XXXXX.grafana.net/otlp
OTEL_INSTANCE_ID=your-instance-id
OTEL_API_TOKEN=your-api-token
